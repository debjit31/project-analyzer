# ─────────────────────────────────────────────────────────────────────────────
# Project Analyzer — Backend Java (Spring Boot)
# Copy this file to .env and fill in the required values.
# The application reads these via application.properties / environment variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── JSearch (RapidAPI) ────────────────────────────────────────────────────────
# Required. Get your key at https://rapidapi.com (subscribe to JSearch — free tier)
JSEARCH_API_KEY=your_rapidapi_key_here

# ── AI Provider ───────────────────────────────────────────────────────────────
# Options: gemini (default) | openai
AI_PROVIDER=gemini

# Required if AI_PROVIDER=gemini — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Required if AI_PROVIDER=openai — get from https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ── Concurrency & Timeouts ────────────────────────────────────────────────────
# Max concurrent AI analysis calls (default: 5, max: 20)
AI_CONCURRENCY_LIMIT=5
# HTTP request timeout in seconds (default: 30, min: 5)
HTTP_TIMEOUT_SECONDS=30.0

# ── Cache ─────────────────────────────────────────────────────────────────────
# TTL for cached job results in seconds (default: 600 = 10 min)
CACHE_TTL_SECONDS=600
# Maximum number of cached search results (default: 128)
CACHE_MAX_SIZE=128

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed frontend origins
APP_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO
